<UserControl x:Class="SimpleTrader.WPF.Controls.NavigationBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SimpleTrader.WPF.Controls"
             xmlns:nav="clr-namespace:SimpleTrader.WPF.State.Navigators"
             xmlns:vm="clr-namespace:SimpleTrader.WPF.ViewModels"
             xmlns:conv="clr-namespace:SimpleTrader.WPF.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <conv:EqualValueToParameterConverter x:Key="EqualityToBooleanConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Background="{StaticResource BrushPrimary1}" RenderOptions.EdgeMode="Aliased">
            <TextBlock Grid.Row="0" Padding="10" FontSize="28" Foreground="White" Text="Simple Trader" MaxWidth="800"/>
        </Grid>
        <Grid Grid.Row="1" Background="{StaticResource BrushPrimary2}" RenderOptions.EdgeMode="Aliased">
            <Grid MaxWidth="800" >
                <Grid.Resources>
                    <Style TargetType="RadioButton" BasedOn="{StaticResource NavButton}"/>
                </Grid.Resources>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <RadioButton Grid.Column="0" Content="Inicio" Command="{Binding UpdateCurrentViewModelCommand}" Tag="/Resources/Icons/Inicio_256.png"
                         IsChecked="{Binding CurrentViewModel, Mode=OneWay, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter={x:Type vm:HomeViewModel}}" 
                         CommandParameter="{x:Static nav:ViewType.Home}"/>
                <RadioButton Grid.Column="1" Content="Cartera" Command="{Binding UpdateCurrentViewModelCommand}" Tag="/Resources/Icons/Cartera.png"
                         IsChecked="{Binding CurrentViewModel, Mode=OneWay, Converter={StaticResource EqualityToBooleanConverter},ConverterParameter={x:Type vm:PortfolioViewModel}}" 
                         CommandParameter="{x:Static nav:ViewType.Portfolio}"/>
                <RadioButton Grid.Column="2" Content="Compra" Command="{Binding UpdateCurrentViewModelCommand}" Tag="/Resources/Icons/Compra.png"
                         IsChecked="{Binding CurrentViewModel, Mode=OneWay, Converter={StaticResource EqualityToBooleanConverter},ConverterParameter={x:Type vm:BuyViewModel}}" 
                         CommandParameter="{x:Static nav:ViewType.Buy}"/>
                <RadioButton Grid.Column="3" Content="Venta" Tag="/Resources/Icons/Venta.png"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
