<UserControl x:Class="SimpleTrader.WPF.Views.BuyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SimpleTrader.WPF.Views"
             xmlns:vm="clr-namespace:SimpleTrader.WPF.ViewModels"
             xmlns:conv="clr-namespace:SimpleTrader.WPF.UI.Converters"
             xmlns:controls="clr-namespace:SimpleTrader.WPF.Controls"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:BuyViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <conv:EmptyStringToZeroConverter x:Key="EmptyStringToZeroConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid Margin="20" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <WrapPanel HorizontalAlignment="Center">
            <TextBox Text="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}" Width="100" CharacterCasing="Upper"/>
            <Button Margin="10 0 0 0" Content="Buscar" Command="{Binding SearchSymbolCommand}" />
        </WrapPanel>
        
        <TextBlock Grid.Row="1" Margin="0 20 0 0" Text="{Binding StatusMessageViewModel.Message}" Foreground="DarkGreen" HorizontalAlignment="Center" 
                   Visibility="{Binding StatusMessageViewModel.HasMessage, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        
        <TextBlock Grid.Row="2" Margin="0 20 0 0" Text="{Binding ErrorMessageViewModel.Message}" Foreground="DarkRed" HorizontalAlignment="Center" 
           Visibility="{Binding ErrorMessageViewModel.HasMessage, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <controls:SearchSymbolResultPanel Margin="0 20 0 0" Grid.Row="3">
            <StackPanel>
                <WrapPanel Margin="0 10">
                    <TextBlock Text="Acciones a comprar:" Width="150" HorizontalAlignment="Left" />
                    <TextBox Text="{Binding SharesToTransfer, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}, Converter={StaticResource EmptyStringToZeroConverter}}" Width="50" HorizontalContentAlignment="Right"/>
                </WrapPanel>
                <WrapPanel Margin="0 10">
                    <TextBlock Text="Precio por acción:" Width="150" />
                    <TextBlock Text="{Binding StockPrice, StringFormat={}{0:C}, FallbackValue='0,00€'}" />
                </WrapPanel>
                <TextBlock Margin="0 10" Text="{Binding TotalPrice, StringFormat=C}" FontSize="32"  HorizontalAlignment="Center"/>
                <Button Content="Comprar" Command="{Binding BuyStockCommand}" FontSize="18" Margin="0 10 0 0" Padding="20 6"/>
            </StackPanel>
        </controls:SearchSymbolResultPanel>

    </Grid>
</UserControl>
