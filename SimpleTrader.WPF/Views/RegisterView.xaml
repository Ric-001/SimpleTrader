<UserControl x:Class="SimpleTrader.WPF.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SimpleTrader.WPF.Views"
             xmlns:vm="clr-namespace:SimpleTrader.WPF.ViewModels"
             xmlns:helpers="clr-namespace:SimpleTrader.WPF.UI.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vm:RegisterViewModel, IsDesignTimeCreatable=False}" FontSize="18" Foreground="{StaticResource BrushPrimary3}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <UserControl.Background>
        <ImageBrush ImageSource="/Resources/Fotos/login-background.jpg" Stretch="UniformToFill" Opacity="0.6"/>
    </UserControl.Background>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="70*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1" BorderBrush="{StaticResource BrushPrimary2}" BorderThickness="3" Margin="20" Padding="30" HorizontalAlignment="Center" CornerRadius="5" Background="White">
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="10"/>
            </Border.Effect>
            <StackPanel>
                <Image Source="/Resources/Icons/SimpleTrader.png" Height="80" Width="80" HorizontalAlignment="Center" Margin="0"/>
                <TextBlock Text="Simple Trader" HorizontalAlignment="Center" FontSize="40" Foreground="{StaticResource BrushPrimary3}" Margin="0 0 0 10"/>
                <TextBlock Text="The world's simplest stock trading application." HorizontalAlignment="Center" FontSize="18" FontWeight="Thin" Foreground="{StaticResource BrushPrimary3}"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Correo:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0 20 0 10"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" Width="200" Margin="0 20 0 10"/>

                    <TextBlock Text="Usuario:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0 10 10 10"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Width="200" Margin="0 10 0 10"/>

                    <TextBlock Text="Contraseña:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0 10 10 10"/>
                    <PasswordBox helpers:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Width="200" Margin="0 10"/>

                    <TextBlock Text="Confirmar:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0 10 10 10"/>
                    <PasswordBox helpers:PasswordBoxHelper.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="3" Grid.Column="1" Width="200" Margin="0 10"/>

                </Grid>
                <Button Content="Registrarse" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Command="{Binding RegisterCommand}" Margin="15 15 15 0" HorizontalAlignment="Center" IsDefault="True"/>
                <Button Grid.Row="5" HorizontalAlignment="Center" Margin="0 10 0 0" Background="Transparent" Foreground="DarkBlue" Content="¿Ya tienes una cuenta?" Command="{Binding ViewLoginCommand}" FontSize="13"/>

                <TextBlock Grid.Row="5" Margin="0 20 0 0" Text="{Binding ErrorMessageViewModel.Message}" Foreground="DarkRed" HorizontalAlignment="Center" 
                           Visibility="{Binding ErrorMessageViewModel.HasMessage, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
        </Border>
    </Grid>

</UserControl>
