<UserControl x:Class="SimpleTrader.WPF.Views.SellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SimpleTrader.WPF.Views"
             xmlns:vm="clr-namespace:SimpleTrader.WPF.ViewModels"
             xmlns:conv="clr-namespace:SimpleTrader.WPF.UI.Converters"
             xmlns:controls="clr-namespace:SimpleTrader.WPF.Controls"
             d:DataContext="{d:DesignInstance Type=vm:SellViewModel, IsDesignTimeCreatable=False}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <conv:EmptyStringToZeroConverter x:Key="EmptyStringToZeroConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ComboBox x:Name="cbAssets" Grid.Row="0" Width="200" ItemsSource="{Binding AssetListingViewModel.Assets}"  HorizontalContentAlignment="Stretch"  
                  SelectedItem="{Binding SelectedAsset}" SelectionChanged="ComboBox_SelectionChanged">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="2"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Symbol}" Margin="5,0"/>
                        <Border Grid.Column="1" BorderBrush="Black" BorderThickness="1 0 0 0"/>
                        <TextBlock Grid.Column="2" Text="{Binding Shares}" Margin="5,0" HorizontalAlignment="Right" TextAlignment="Right"/>
                    </Grid>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock Grid.Row="1" Margin="0 20 0 0" Text="{Binding StatusMessageViewModel.Message}" Foreground="DarkGreen" HorizontalAlignment="Center" 
           Visibility="{Binding StatusMessageViewModel.HasMessage, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <TextBlock Grid.Row="2" Margin="0 20 0 0" Text="{Binding ErrorMessageViewModel.Message}" Foreground="DarkRed" HorizontalAlignment="Center" 
            Visibility="{Binding ErrorMessageViewModel.HasMessage, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <controls:SearchSymbolResultPanel Margin="0 20 0 0" Grid.Row="3">
            <StackPanel>
                <WrapPanel Margin="0 10">
                    <TextBlock Text="Acciones a la venta:" Width="150" HorizontalAlignment="Left" />
                    <TextBox Text="{Binding SharesToTransfer, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}, Converter={StaticResource EmptyStringToZeroConverter}}" Width="50" HorizontalContentAlignment="Right"/>
                </WrapPanel>
                <WrapPanel Margin="0 10">
                    <TextBlock Text="Precio por acción:" Width="150" />
                    <TextBlock Text="{Binding StockPrice, StringFormat={}{0:C}, FallbackValue='0,00€'}" />
                </WrapPanel>
                <TextBlock Margin="0 10" Text="{Binding TotalPrice, StringFormat=C}" FontSize="32"  HorizontalAlignment="Center"/>
                <Button Content="Vender" Command="{Binding SellStockCommand}" FontSize="18" Margin="0 10 0 0" Padding="20 6"/>
            </StackPanel>
        </controls:SearchSymbolResultPanel>
    </Grid>
</UserControl>
