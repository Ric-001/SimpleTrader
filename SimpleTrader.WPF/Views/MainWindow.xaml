<Window x:Class="SimpleTrader.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleTrader.WPF"
        xmlns:controls="clr-namespace:SimpleTrader.WPF.Controls"
        xmlns:vm="clr-namespace:SimpleTrader.WPF.ViewModels"
        xmlns:conv="clr-namespace:SimpleTrader.WPF.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Icon="/Resources/Icons/SimpleTrader.ico"
        Title="Simple Trader" Height="520" Width="800">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Visibility="{Binding Authenticator.IsLoggedIn, Converter={StaticResource BoolToVisibilityConverter}}">
            <controls:NavigationBar />
        </Grid>
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ContentControl  Content="{Binding Navigator.CurrentViewModel}"/>
        </ScrollViewer>

    </Grid>
</Window>
